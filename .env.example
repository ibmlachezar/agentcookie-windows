# Your agent machine (the second machine your agent runs on)
# Get the Tailscale IP from: tailscale ip -4
AGENT_HOST=100.x.x.x
AGENT_USER=your_username

# Path to your SSH private key (optional - uses default if not set)
AGENT_SSH_KEY=C:\Users\you\.ssh\id_rsa

# Where to sync on the agent machine
AGENT_COOKIE_DIR=~/.agentcookie

# How often to check for changes (seconds)
WATCH_INTERVAL=30
